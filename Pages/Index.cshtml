@page
@model IndexModel
@{
    ViewData["Title"] = "URL Shortener";
}

<div class="row justify-content-center mt-5">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6">

        <div class="text-center mb-4">
            <div class="mb-3">
                <span class="display-1">🔗</span>
            </div>
            <h1 class="fw-bold">URL Shortener</h1>
            <p class="text-muted">Paste a long URL and get a short, shareable link instantly.</p>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input type="url"
                               asp-for="NewUrl"
                               class="form-control @(ViewData.ModelState["NewUrl"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               id="NewUrl"
                               placeholder="https://example.com/very/long/url" />
                        <label for="NewUrl">Paste your long URL here</label>
                        <span asp-validation-for="NewUrl" class="invalid-feedback"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Shorten URL
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ShortenedUrl))
        {
            <div class="card mt-3 border-success shadow-sm">
                <div class="card-body p-4">
                    <h6 class="card-subtitle mb-2 text-muted small text-uppercase fw-semibold">Your shortened URL</h6>
                    <div class="input-group">
                        <input type="text"
                               id="shortenedUrlInput"
                               class="form-control form-control-lg fw-semibold text-success"
                               value="@Model.ShortenedUrl"
                               readonly />
                        <button class="btn btn-outline-success"
                                type="button"
                                onclick="copyToClipboard()"
                                title="Copy to clipboard">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
                                <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
                            </svg>
                        </button>
                    </div>
                    <div id="copyFeedback" class="text-success small mt-1" style="display:none;">Copied to clipboard!</div>
                    <a href="@Model.ShortenedUrl" target="_blank" class="btn btn-sm btn-link text-success px-0 mt-1">
                        Open link ↗
                    </a>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyToClipboard() {
            const input = document.getElementById('shortenedUrlInput');
            navigator.clipboard.writeText(input.value).then(() => {
                const feedback = document.getElementById('copyFeedback');
                feedback.style.display = 'block';
                setTimeout(() => feedback.style.display = 'none', 2000);
            });
        }
    </script>
}
