@page
@model IndexModel
@{
    ViewData["Title"] = "URL Shortener";
}

<div class="flex justify-center mt-10 px-4">
    <div class="w-full max-w-md">

        <div class="text-center mb-6">
            <div class="mb-3 text-6xl">
                🔗
            </div>
            <h1 class="text-3xl font-bold mb-2">URL Shortener</h1>
            <p class="text-gray-500">Paste a long URL and get a short, shareable link instantly.</p>
        </div>

        <div class="card bg-base-100 shadow-lg border border-base-300">
            <div class="card-body p-6">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-error alert-soft mb-4" role="alert"></div>
                    <div class="mb-4">
                        <label class="w-full input input-bordered flex items-center gap-2 @(ViewData.ModelState["NewUrl"]?.Errors.Count > 0 ? "input-error" : "")">
                            <input type="url"
                                   asp-for="NewUrl"
                                   class="grow"
                                   placeholder="https://example.com/very/long/url" />
                        </label>
                        <label class="label">
                            <span class="label-text-alt">Paste your long URL here</span>
                            <span asp-validation-for="NewUrl" class="label-text-alt text-error"></span>
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary w-full btn-lg">
                        Shorten URL
                    </button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ShortenedUrl))
        {
            <div class="card bg-base-100 border border-success shadow-lg mt-4">
                <div class="card-body p-6">
                    <h6 class="font-bold text-sm text-gray-500 uppercase mb-3">Your shortened URL</h6>
                    <div class="join w-full">
                        <input type="text"
                               id="shortenedUrlInput"
                               class="input input-bordered join-item flex-grow font-semibold text-success"
                               value="@Model.ShortenedUrl"
                               readonly />
                        <button class="btn btn-primary join-item"
                                type="button"
                                onclick="copyToClipboard()"
                                title="Copy to clipboard">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
                                <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
                            </svg>
                        </button>
                    </div>
                    <div id="copyFeedback" class="text-success text-sm mt-2" style="display:none;">Copied to clipboard!</div>
                    <a href="@Model.ShortenedUrl" target="_blank" class="link link-success text-sm mt-2 inline-block">
                        Open link ↗
                    </a>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyToClipboard() {
            const input = document.getElementById('shortenedUrlInput');
            navigator.clipboard.writeText(input.value).then(() => {
                const feedback = document.getElementById('copyFeedback');
                feedback.style.display = 'block';
                setTimeout(() => feedback.style.display = 'none', 2000);
            });
        }
    </script>
}
